{
  "name": "@riddance/dynamodb-docs",
  "type": "module",
  "version": "0.0.3",
  "engines": {
    "node": ">=24"
  },
  "files": [
    "*.js",
    "lib/*.js",
    "*.d.ts"
  ],
  "exports": {
    ".": "./partitioned.js",
    "./schema": "./schema.js",
    "./test/mock": "./mock.js"
  },
  "scripts": {
