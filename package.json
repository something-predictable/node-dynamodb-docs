    "prepack": "riddance-build",
    "prepublishOnly": "riddance-prepublish",
    "postpublish": "riddance-sync"
  },
  "dependencies": {
    "@riddance/docs": "0.0.3",
    "@riddance/fetch": "0.1.4",
    "@smithy/signature-v4": "5.4.3"
  },
  "devDependencies": {
    "@riddance/env": "0.10.0"
  }
}
